# 复制为 .env 后填入真实值：cp .env.example .env
# 详细说明见 README.md 与 docs/OpenAI兼容API接入方案.md

# ========== 鉴权（二选一）==========
ANTHROPIC_AUTH_TOKEN=your_token_here
# ANTHROPIC_API_KEY=your_api_key_here

# ========== OpenAI 兼容（one-api / OpenRouter 等 Chat Completions 网关）==========
# 设为 1/true：走 POST /v1/chat/completions；多数「OpenAI 格式」聚合站需开启。
# 不设或 false：走 Anthropic Messages API（需网关支持 /v1/messages）。
CLAUDE_CODE_USE_OPENAI_COMPAT_API=

# ========== 仅 Anthropic SDK 时的 URL 辅助 ==========
# 与上一项不同：仍用 Anthropic 协议，只自动去掉 ANTHROPIC_BASE_URL 末尾 /v1，避免 /v1/v1/messages。
# 开启 OpenAI 兼容时通常留空或 false 即可。
CLAUDE_CODE_OPENAI_COMPATIBLE_API=

# 网关根地址（不要加引号）。
# - OpenAI 兼容：最终请求 {有/v1则用}{BASE}/chat/completions，无则自动补 /v1
# - Anthropic：填支持 Messages API 的地址，如 https://api.minimaxi.com/anthropic
ANTHROPIC_BASE_URL=https://your-gateway.example/v1

# 可选：仅 OpenAI 兼容时覆盖上面的地址（一般与 ANTHROPIC_BASE_URL 相同即可）
# CLAUDE_CODE_OPENAI_BASE_URL=https://your-gateway.example/v1

# 可选：合并进 Chat Completions 请求体的 JSON 对象（不覆盖 model / messages / stream）
# CLAUDE_CODE_OPENAI_EXTRA_BODY={"top_p":0.95}

# ========== OpenAI 兼容：多服务商（.env 声明）+ Zen 免费（运行时拉取，不写回 .env）==========
# 仅在 CLAUDE_CODE_USE_OPENAI_COMPAT_API=1 时生效。
#
# 1) 额外 OpenAI 兼容网关：JSON 数组。模型在 /model 中选「providerId/模型名」，请求会打到对应 baseUrl。
#    密钥用 apiKey 或 apiKeyEnv（后者读已有环境变量名）。models 非空时仅允许列出的模型；省略 models 则允许任意 providerId/xxx。
# CLAUDE_CODE_COMPAT_PROVIDERS_JSON=[{"id":"deepseek","baseUrl":"https://api.deepseek.com/v1","apiKeyEnv":"DEEPSEEK_API_KEY","models":["deepseek-chat","deepseek-reasoner"]}]
# 模型名含 / 时：/model 选 deepseek/Qwen/Qwen3-xxx（第一个 / 为分隔，右侧整段为 API 的 model）
# CLAUDE_CODE_COMPAT_PROVIDERS_JSON=[{"id":"ms","baseUrl":"https://api-inference.modelscope.cn/v1","apiKeyEnv":"MODELSCOPE_API_KEY","models":["Qwen/Qwen3.5-122B-A10B"]}]
#
# 2) OpenCode Zen 免费层：设为 1 后启动时拉取 https://opencode.ai/zen/v1/models，/model 中出现 zen/<模型ID>，使用 Bearer public。
#    若同时设置 CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1，将跳过拉取（与 bootstrap 一致）。
# CLAUDE_CODE_ZEN_FREE_MODELS=1

# ========== 模型（按网关后台实际名称填写）==========
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7-highspeed
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7-highspeed
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7-highspeed
ANTHROPIC_MODEL=your-model-name

# ========== 其它 ==========
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_TELEMETRY=1

# TUI 首次启动会全屏显示引导与「信任工作区」；若终端上像卡住，可仅在受信目录设为 1 跳过（会写入 ~/.claude.json，并静默接受当前 ANTHROPIC_API_KEY、跳过 MCP/设置错误等阻塞对话框）。
# CLAUDE_CODE_SKIP_STARTUP_DIALOGS=1

# 在 stderr 为 TTY 时输出分步启动诊断（Claude Code〔启动〕…、Ink 帧等）。默认关闭，避免与全屏 TUI 叠显变乱；与上一项无绑定。
# CLAUDE_CODE_STARTUP_PROGRESS=1

# external 构建默认「主缓冲 + 滚动区」主界面；设为 1/true 则启用全屏 REPL（备用缓冲 ?1049h，与 ant 构建默认行为接近）。
# CLAUDE_CODE_NO_FLICKER=1
